{
  "permissions": {
    "allow": [
      "Bash(npm test:*)",
      "Bash(npm rebuild:*)",
      "WebFetch(domain:ssh.github.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "Bash(rtk vitest:*)",
      "Bash(rtk npm:*)",
      "Bash(rtk read:*)",
      "Bash(node_modules/.bin/vitest run:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(echo \"exit=$?\")",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:release-assets.githubusercontent.com)",
      "WebFetch(domain:docs.github.com)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
