{
  "name": "local-code-review",
  "version": "0.0.1",
  "description": "Local Electron PR review app",
  "main": "./out/main/index.js",
  "author": "",
  "homepage": "./",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck": "tsc --build tsconfig.node.json && tsc --noEmit",
    "start": "electron-vite preview",
    "dev": "electron-vite",
    "build:mcp": "vite build --config vite.mcp.config.ts",
    "generate-icon": "node scripts/generate-icon.js",
    "build": "npm run build:mcp && npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --publish never",
    "dist:mac": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:win:zip": "npm run build && electron-builder --win zip --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "test": "vitest --workspace vitest.workspace.ts",
    "test:main": "vitest --workspace vitest.workspace.ts --project main",
    "test:renderer": "vitest --workspace vitest.workspace.ts --project renderer"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.10.0",
    "highlight.js": "^11.11.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "uuid": "^9.0.1",
    "zod": "^4.3.6",
    "zustand": "^4.4.6"
  },
  "build": {
    "appId": "com.local-code-review",
    "productName": "Local Code Review",
    "copyright": "Alex Luckett",
    "directories": {
      "output": "dist"
    },
    "files": ["out/**/*"],
    "asarUnpack": ["**/*.node", "node_modules/better-sqlite3/**/*"],
    "extraResources": [
      { "from": "resources/iconTemplate.png", "to": "iconTemplate.png" },
      { "from": "resources/iconTemplate@2x.png", "to": "iconTemplate@2x.png" },
      { "from": "resources/icon-512.png", "to": "icon-512.png" }
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}",
      "icon": "resources/icon.icns"
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "zip", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "icon": "resources/icon-512.png",
      "category": "Development",
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] },
        { "target": "deb", "arch": ["x64"] }
      ]
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^1.1.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "electron-vite": "^2.0.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "jsdom": "^23.0.1",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.4",
    "vitest": "^1.1.0"
  }
}
